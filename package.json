{
  "name": "taiwan-election-report-v6-1-12",
  "version": "6.1.12",
  "private": true,
  "description": "台灣選舉報報：官方現任、候選人與歷屆資料同步，依政黨分組並支援全資料抓取",
  "type": "module",
  "scripts": {
    "build:data": "node scripts/build-client-data.mjs",
    "sync:candidates": "node scripts/sync-official-data.mjs",
    "sync:officeholders": "node scripts/sync-officeholders.mjs",
    "sync": "node scripts/sync-all.mjs",
    "validate": "node scripts/validate-data.mjs && node scripts/check-generated-data.mjs",
    "test": "npm run test:moi-parser && npm run test:cec-parser && npm run sync:history && npm run report:changes && npm run build:shards && npm run build:data && npm run validate",
    "serve": "python3 -m http.server 8080",
    "sync:history": "node scripts/sync-history.mjs",
    "sync:history:official": "node scripts/sync-cec-history.mjs",
    "test:cec-parser": "python3 scripts/test_cec_history_import.py",
    "cache:portraits": "python3 scripts/cache_portraits.py",
    "report:changes": "node scripts/generate-change-report.mjs",
    "build:shards": "node scripts/build-data-shards.mjs",
    "build:release": "npm run cache:portraits && npm run sync:history && npm run report:changes && npm run build:shards && npm run build:data",
    "test:moi-parser": "MOI_PARSER_TEST=1 node scripts/test-moi-parser.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
